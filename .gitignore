# ── 敏感配置（绝对不能提交）────────────────────────────────
.env
certs/

# ── Python 编译产物 ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── 虚拟环境 ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── 数据库文件（含 SQLite WAL 文件）───────────────────────────
*.db
*.db-shm
*.db-wal

# ── 存储数据（DICOM、切片、上传文件等）────────────────────────
storage/uploads/
storage/processed/
storage/exports/
storage/chunks/

# ── 日志 ─────────────────────────────────────────────────────
*.log
logs/

# ── Docker 构建缓存（本地调试用）────────────────────────────
.docker/

# ── macOS 系统文件 ────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 构建产物 ─────────────────────────────────────────────────
dist/
build/
*.egg-info/

# ── 测试 / 覆盖率 ────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/