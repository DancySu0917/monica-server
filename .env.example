# ═══════════════════════════════════════════════════════════════
# Monica Medical AI Server - 环境变量模板
# 使用方式：cp .env.example .env  然后填写真实值
# 注意：.env 文件绝对不能提交到 Git！
# ═══════════════════════════════════════════════════════════════

# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=06627f9f77ad9e6b2ed69c95bd9420c971f4065361924ba4a198b97091c31498

# ── 微信小程序 ──────────────────────────────────────────────────
WX_APPID=wx3049de7a1babc585
WX_SECRET=ae4bd8700c5be8780e664c68f6ca7ed8

# ── 数据库 ──────────────────────────────────────────────────────
# Docker 部署时数据库文件放在 volume 中
DATABASE_URL=sqlite:////opt/monica-server/db/monica.db

# ── Redis（Docker Compose 时 host 为 service name "redis"）──────
REDIS_URL=redis://redis:6379/0

# ── LLM 配置 ────────────────────────────────────────────────────
# 默认模型（api.b.ai 降级链起点）
DEFAULT_MODEL=gpt-5.4-nano

# api.b.ai（首选，OpenAI 兼容协议，支持最新 Gemini 模型）
BAI_API_KEY=sk-s10qhts2yokcrvxf12rkr8jb7xkc70j4
BAI_BASE_URL=https://api.b.ai/v1

# Evolink 代理（api.b.ai 不可用时备用，Gemini 原生协议）
EVOLINK_API_KEY=sk-KAFfp7VjkrZt6AEIDoD6abUwOh3BvH1u1FeqOWjlAvJ4SonE
EVOLINK_BASE_URL=https://direct.evolink.ai/v1


# ── 存储 ────────────────────────────────────────────────────────
# Docker 部署时使用容器内绝对路径
STORAGE_ROOT=/opt/monica-server/storage
MAX_UPLOAD_SIZE_MB=500
CHUNK_SIZE_MB=5

# ── 配额保护 ────────────────────────────────────────────────────
DAILY_TOKEN_LIMIT=200000

# ── 性能（适配 2C2G 服务器）────────────────────────────────────
ARQ_MAX_JOBS=2
ARQ_JOB_TIMEOUT=600
DICOM_BATCH_SIZE=50
TOP_K_SLICES=10
TOTALSEG_FAST=true

# ── CORS（填写真实域名，多个用逗号分隔）────────────────────────
ALLOWED_ORIGINS=https://codebetter.cn, https://api.codebetter.cn

# ── 开发模式（⚠️ 生产环境必须为 false 或不设置）─────────────────
# 设为 true 后允许用 code="monica-code" 或 "dev_xxx" 绕过微信登录
DEV_MODE=true
