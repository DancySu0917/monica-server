# ═══════════════════════════════════════════════════════════════
# Monica Medical AI Server - 环境变量模板
# 使用方式：cp .env.example .env  然后填写真实值
# 注意：.env 文件绝对不能提交到 Git！
# ═══════════════════════════════════════════════════════════════

APP_ENV=production

# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-min-32-chars-please-change-this

# ── 微信小程序 ──────────────────────────────────────────────────
WX_APPID=wx_your_appid_here
WX_SECRET=your_wx_secret_here

# ── 数据库 ──────────────────────────────────────────────────────
# Docker 部署时数据库文件放在 volume 中
DATABASE_URL=sqlite:////opt/monica-server/db/monica.db

# ── Redis（Docker Compose 时 host 为 service name "redis"）──────
REDIS_URL=redis://redis:6379/0

# ── LLM 配置 ────────────────────────────────────────────────────
# 支持: gemini-2.5-flash / gemini-2.0-flash / gemini-1.5-flash
DEFAULT_MODEL=gemini-2.5-flash

# Evolink 代理（生产环境推荐，Gemini 协议 + Bearer 鉴权）
EVOLINK_API_KEY=sk-your-evolink-api-key-here
EVOLINK_BASE_URL=https://direct.evolink.ai/v1beta/models 

# Ollama 本地部署（APP_ENV=development 时自动生效）
OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions
OLLAMA_DEFAULT_MODEL=amsaravi/medgemma-4b-it:q6

# ── 存储 ────────────────────────────────────────────────────────
# Docker 部署时使用容器内绝对路径
STORAGE_ROOT=/opt/monica-server/storage
MAX_UPLOAD_SIZE_MB=500
CHUNK_SIZE_MB=5

# ── 配额保护 ────────────────────────────────────────────────────
DAILY_TOKEN_LIMIT=200000

# ── 性能（适配 2C2G 服务器）────────────────────────────────────
ARQ_MAX_JOBS=1
ARQ_JOB_TIMEOUT=600
DICOM_BATCH_SIZE=50
TOP_K_SLICES=10
TOTALSEG_FAST=true

# ── CORS（生产环境填写真实域名，多个用逗号分隔）────────────────
# ALLOWED_ORIGINS=https://your-domain.com ,https://www.your-domain.com 